
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>My Blog</title>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">
    <!-- Alert Messages -->
    <% if (success) { %>
        <div class="fixed top-4 right-4 z-50 max-w-md transition-all duration-300 ease-out animate-in slide-in-from-top-2">
            <div class="bg-green-50 border-l-4 border-green-500 rounded-lg shadow-lg p-4 flex items-center gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <p class="text-green-800 font-medium"><%= success %></p>
                <button onclick="this.parentElement.parentElement.remove()" class="ml-auto text-green-600 hover:text-green-800">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                </button>
            </div>
        </div>
    <% } %>

    <% if (error) { %>
        <div class="fixed top-4 right-4 z-50 max-w-md transition-all duration-300 ease-out">
            <div class="bg-red-50 border-l-4 border-red-500 rounded-lg shadow-lg p-4 flex items-center gap-3">
                <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
                <p class="text-red-800 font-medium"><%= error %></p>
                <button onclick="this.parentElement.parentElement.remove()" class="ml-auto text-red-600 hover:text-red-800">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                </button>
            </div>
        </div>
    <% } %>

    <!-- Main Content Container -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
        <!-- Blog Post Card -->
        <article class="flex flex-col items-center bg-white rounded-2xl shadow-xl overflow-hidden mb-8 transition-shadow duration-300 hover:shadow-2xl">
            <!-- Cover Image -->
            <% if (blog.coverImgUrl) { %>
                <div class="relative h-64 sm:h-96 md:h-70 w-120 overflow-hidden rounded-sm bg-gray-200">
                    <img src="<%= blog.coverImgUrl %>" alt="Blog cover image" class="w-full h-full object-cover rounded- transition-transform duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
                </div>
            <% } %>

            <!-- Blog Content -->
            <div class="p-6 sm:p-8 md:p-10 mt-8 w-full">
                <!-- Title -->
                <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-gray-900 mb-4 leading-tight tracking-tight"><%= blog.title %></h1>
                
                <!-- Author Info -->
                <div class="flex items-center justify-between flex-wrap gap-4 mt-8 mb-8 pb-6 border-b border-gray-200">
                    <div class="flex items-center gap-3">
                        <% if (blog.author && blog.author.profileImgUrl) { %>
                            <img src="<%= blog.author.profileImgUrl %>" alt="<%= blog.author.username %>" class="w-12 h-12 rounded-full object-cover ring-2 ring-white shadow-md">
                        <% } else { %>
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-lg shadow-md">
                                <%= blog.author && blog.author.username ? blog.author.username.charAt(0).toUpperCase() : 'U' %>
                            </div>
                            
                        <% } %>
                        
                        <div>
                             <div class="flex items-center  gap-4">
                              <p class="font-semibold text-gray-900"><%= blog.author ? blog.author.username : 'Anonymous' %></p>
                         <%
                            const isLoggedIn = !!user;

                            const isOwnBlog =
                                isLoggedIn &&
                                user._id &&
                                blog.author &&
                                blog.author._id &&
                                user._id.toString() === blog.author._id.toString();

                            const alreadySubscribed =
                                isLoggedIn &&
                                user.subscribedto &&
                                blog.author &&
                                blog.author._id &&
                                user.subscribedto.some(
                                    id => id.toString() === blog.author._id.toString()
                                );
                            %>
                            <% if (!isOwnBlog) { %>

                             <% if (!isLoggedIn) { %>

                             
                                <a 
                                    href="/users/login"
                                    class="font-semibold text-blue-800 underline hover:text-blue-900 transition-colors"
                                >
                                    Subscribe
                                </a>


                                <% } else if (alreadySubscribed) { %>

                                    <button
                                        disabled
                                        class="font-semibold text-gray-500 cursor-not-allowed"
                                    >
                                        Subscribed
                                    </button>

                                <% } else { %>

                                    <form action="/users/subscribe/<%= blog.author._id %>" method="POST">
                                        <button 
                                            type="submit"
                                            class="font-semibold text-blue-800 underline hover:text-blue-900 transition-colors"
                                        >
                                            Subscribe
                                        </button>
                                    </form>

                                <% } %>

                            <% } %>
                            </div>
                            <p class="text-sm text-gray-500">Published on <%= blog.createdAt ? blog.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '' %></p>
                        </div>
                    </div>
                   
                    
                    <!-- Action Buttons for Author -->
                    <% if (user && user.id && blog.author && blog.author._id && user.id.toString() === blog.author._id.toString()) { %>
                        <div class="flex gap-3">
                            <a href="/blog/edit/<%= blog._id %>" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-xl transition-all duration-200 shadow-sm hover:shadow-md focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                               
                            </a>
                            <form action="/blog/delete/<%= blog._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this blog? This action cannot be undone.')">
                                <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white font-medium rounded-xl transition-all duration-200 shadow-sm hover:shadow-md focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    
                                </button>
                            </form>
                        </div>
                    <% } %>
                </div>

                <!-- Blog Content Body -->
                <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
                    <p class="whitespace-pre-wrap font-serif text-lg leading-loose"><%= blog.content %></p>
                </div>
            </div>
        </article>

        <!-- Comments Section -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="p-6 sm:p-8">
                <!-- Comments Header -->
                <div class="flex items-center gap-3 mb-6">
                    <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    <h2 class="text-2xl font-bold text-gray-900">Comments</h2>
                    <span class="bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-full text-sm font-medium">
                        <%= comments ? comments.length : 0 %>
                    </span>
                </div>

                <!-- Add Comment Form -->
                <% if (user) { %>
                    <form action="/blog/add-comment/<%= blog._id %>" method="POST" class="mb-8 bg-gray-50 rounded-xl p-5 border border-gray-200">
                        <div class="mb-4">
                            <label for="content" class="block text-gray-700 font-semibold mb-2">Write your thoughts...</label>
                            <textarea 
                                name="content" 
                                id="content" 
                                rows="4" 
                                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 resize-none"
                                placeholder="Share your comment about this blog post..."
                                required
                            ></textarea>
                        </div>
                        <div class="flex justify-end">
                            <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-xl transition-all duration-200 shadow-sm hover:shadow-md focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                Post Comment
                            </button>
                        </div>
                    </form>
                <% } else { %>
                    <div class="mb-8 bg-blue-50 rounded-xl p-5 border border-blue-200 text-center">
                        <p class="text-blue-800">
                            <a href="/users/login" class="font-semibold underline hover:text-blue-900 transition-colors">Login</a> to leave a comment
                        </p>
                    </div>
                <% } %>

                <!-- Comments List -->
                <div class="max-h-[600px] overflow-y-auto pr-2 space-y-4">
                    <% if (comments && comments.length > 0) { %>
                        <% comments.forEach(comment => { %>
                            <div class="bg-white border border-gray-200 rounded-xl p-5 transition-all duration-200 hover:border-gray-300 hover:shadow-md hover:translate-x-1">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-3 mb-3">
                                            <% if (comment.author && comment.author.profileImgUrl) { %>
                                                <img src="<%= comment.author.profileImgUrl %>" alt="<%= comment.author.username %>" class="w-8 h-8 rounded-full object-cover">
                                            <% } else { %>
                                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-teal-600 flex items-center justify-center text-white font-bold text-sm">
                                                    <%= comment.author && comment.author.username ? comment.author.username.charAt(0).toUpperCase() : 'A' %>
                                                </div>
                                            <% } %>
                                            <div>
                                                <span class="font-semibold text-gray-900"><%= comment.author && comment.author.username ? comment.author.username : 'Anonymous' %></span>
                                                <span class="text-xs text-gray-400 ml-2">
                                                    <%= comment.createdAt ? new Date(comment.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Just now' %>
                                                </span>
                                            </div>
                                        </div>
                                        <p class="text-gray-700 leading-relaxed"><%= comment.content %></p>
                                    </div>
                                    
                                    <!-- Delete comment button for author -->
                                    <% if (user && user.id && comment.author && comment.author._id && user.id.toString() === comment.author._id.toString()) { %>
                                        <form action="/blog/delete-comment/<%= comment._id %>?_method=DELETE" method="POST" class="flex-shrink-0">
                                            <button type="submit" class="text-gray-400 hover:text-red-600 transition-colors duration-200 p-1" onclick="return confirm('Delete this comment?')">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-12 bg-gray-50 rounded-xl">
                            <svg class="w-16 h-16 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                            </svg>
                            <p class="text-gray-500">No comments yet. Be the first to share your thoughts!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Back to Top Button -->
    <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="fixed bottom-6 right-6 bg-white rounded-full p-3 shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-blue-500" id="backToTop">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
        </svg>
    </button>

    <script>
        // Show/hide back to top button
        const backToTop = document.getElementById('backToTop');
        if (backToTop) {
            backToTop.classList.add('opacity-0', 'invisible');
            window.addEventListener('scroll', () => {
                if (window.pageYOffset > 300) {
                    backToTop.classList.remove('opacity-0', 'invisible');
                    backToTop.classList.add('opacity-100', 'visible');
                } else {
                    backToTop.classList.add('opacity-0', 'invisible');
                    backToTop.classList.remove('opacity-100', 'visible');
                }
            });
        }

        // Auto-dismiss alerts after 5 seconds
        setTimeout(() => {
            document.querySelectorAll('.fixed.top-4.right-4').forEach(alert => {
                alert.style.opacity = '0';
                alert.style.transform = 'translateX(100%)';
                setTimeout(() => alert.remove(), 300);
            });
        }, 5000);
    </script>

    <%- include('partials/scripts') %>
</body>
</html>
